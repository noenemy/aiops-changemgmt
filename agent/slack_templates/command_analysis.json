{
  "blocks": [
    {
      "type": "header",
      "text": { "type": "plain_text", "text": "🔄 재분석 완료 — PR #{{pr_number}}" }
    },
    {{>sections/pr_fields}},
    { "type": "divider" },
    {{>sections/summary}}
    {{#if issues_text}},
    {{>sections/issues_list}}
    {{/if}}
    {{#if incident_match}},
    {{>sections/incident_match}}
    {{/if}},
    {{>sections/footer}}
  ]
}
