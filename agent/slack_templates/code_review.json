{
  "blocks": [
    {{>sections/pr_header}},
    {{>sections/pr_fields}},
    {{>sections/risk_bar}},
    { "type": "divider" }
    {{#if summary}},
    {{>sections/summary}}
    {{/if}}
    {{#if code_block}},
    {{>sections/code_block}}
    {{/if}}
    {{#each issues}}
    ,{ "type": "divider" },
    {{>sections/issue_item}}
    {{/each}}
    {{#if incident_code}}
    ,{ "type": "divider" },
    {{>sections/incident_code}}
    {{/if}}
    {{#if developer_pattern}}
    ,{ "type": "divider" },
    {{>sections/developer_pattern}}
    {{/if}}
    ,{ "type": "divider" },
    {{>sections/footer}}
  ]
}
