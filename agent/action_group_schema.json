{
  "openapi": "3.0.0",
  "info": {
    "title": "AIOps ChangeManagement Tools",
    "version": "2.0.0",
    "description": "Tools exposed to the Bedrock Agent (mirror of FunctionSchema in agent-template.yaml)"
  },
  "paths": {
    "/get_pr_diff":                { "get":  { "operationId": "get_pr_diff",                "parameters": [{"name":"pr_number","in":"query","required":true,"schema":{"type":"integer"}}] } },
    "/get_pr_files":               { "get":  { "operationId": "get_pr_files",               "parameters": [{"name":"pr_number","in":"query","required":true,"schema":{"type":"integer"}}] } },
    "/detect_change_type":         { "get":  { "operationId": "detect_change_type",         "parameters": [{"name":"pr_number","in":"query","required":true,"schema":{"type":"integer"}}] } },
    "/get_review_history":         { "get":  { "operationId": "get_review_history",         "parameters": [
      {"name":"author","in":"query","required":false,"schema":{"type":"string"}},
      {"name":"files","in":"query","required":false,"schema":{"type":"string"}},
      {"name":"limit","in":"query","required":false,"schema":{"type":"integer"}}
    ] } },
    "/get_developer_profile":      { "get":  { "operationId": "get_developer_profile",      "parameters": [{"name":"author","in":"query","required":true,"schema":{"type":"string"}}] } },
    "/get_team_stats":             { "get":  { "operationId": "get_team_stats",             "parameters": [
      {"name":"team_id","in":"query","required":true,"schema":{"type":"string"}},
      {"name":"period","in":"query","required":false,"schema":{"type":"string"}}
    ] } },
    "/invoke_devops_agent":        { "post": { "operationId": "invoke_devops_agent",        "parameters": [
      {"name":"query","in":"query","required":true,"schema":{"type":"string"}},
      {"name":"context","in":"query","required":false,"schema":{"type":"string"}}
    ] } },
    "/invoke_security_agent":      { "post": { "operationId": "invoke_security_agent",      "parameters": [
      {"name":"query","in":"query","required":true,"schema":{"type":"string"}},
      {"name":"context","in":"query","required":false,"schema":{"type":"string"}}
    ] } },
    "/post_github_comment":        { "post": { "operationId": "post_github_comment",        "parameters": [
      {"name":"pr_number","in":"query","required":true,"schema":{"type":"integer"}},
      {"name":"comment_body","in":"query","required":true,"schema":{"type":"string"}}
    ] } },
    "/post_github_fix_suggestion": { "post": { "operationId": "post_github_fix_suggestion", "parameters": [
      {"name":"pr_number","in":"query","required":true,"schema":{"type":"integer"}},
      {"name":"suggestion_markdown","in":"query","required":true,"schema":{"type":"string"}}
    ] } },
    "/post_slack_report":          { "post": { "operationId": "post_slack_report",          "parameters": [
      {"name":"report_json","in":"query","required":true,"schema":{"type":"string"}}
    ] } }
  }
}
